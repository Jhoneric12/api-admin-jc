
generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "mysql"
}

model Credentials {
  id           Int      @id @default(autoincrement())
  accountId    String   @unique @default(uuid())
  email        String   @unique
  password     String
  dateCreated  DateTime @default(now())
  dateUpdated  DateTime @updatedAt

  admin        Admin?
}

model Admin {
  id            Int         @id @default(autoincrement())
  adminId       String      @unique @default(uuid())

  accountId     String      @unique
  firstName     String
  lastName      String
  birthdate     DateTime    @db.Date
  mobileNumber  String
  gender        String
  dateCreated   DateTime    @default(now())
  dateUpdated   DateTime    @updatedAt

  credentials   Credentials @relation(fields: [accountId], references: [accountId])
}

model Product {
  id           Int      @id @default(autoincrement())
  productId    String   @unique @default(uuid())
  prefix       String   @unique
  name         String
  description  String?
  imageSrc     String?
  categoryId   String
  isActive     Boolean  @default(true)

  category     Category @relation(fields: [categoryId], references: [categoryId])
  variants     ProductVariant[]

  dateCreated  DateTime @default(now())
  dateUpdated  DateTime @updatedAt
}

model Unit {
  id            Int     @id @default(autoincrement())
  unitId        String  @unique @default(uuid())
  name          String  // Milliliter, Piece, Box
  abbreviation  String  // ml, pc, box

  variants      ProductVariant[]

  dateCreated   DateTime @default(now())
  dateUpdated   DateTime @updatedAt 
}

model Category {
  id           Int        @id @default(autoincrement())
  categoryId   String     @unique @default(uuid())
  name         String
  products     Product[]

  dateCreated  DateTime   @default(now())
  dateUpdated  DateTime   @updatedAt
}

model ProductVariant {
  id                 Int      @id @default(autoincrement())
  productVariantId   String   @unique @default(uuid())
  unitId             String
  productId          String
  sku                String   @unique
  value              Float    // 30, 50
  costPrice          Decimal  @db.Decimal(10, 2)
  sellPrice          Decimal  @db.Decimal(10, 2)

  product            Product  @relation(fields: [productId], references: [productId])
  unit               Unit     @relation(fields: [unitId], references: [unitId])
  inventory          Inventory?
  saleItems          SaleItem[]
  movements          StockMovement[]

  dateCreated        DateTime @default(now())
  dateUpdated        DateTime @updatedAt 
}

model Inventory {
  id            Int @id @default(autoincrement())
  inventoryId   String   @unique @default(uuid())
  variantId     String @unique
  quantity      Int @default(0)
  reorderLvl    Int @default(10)

  variant       ProductVariant @relation(fields: [variantId], references: [productVariantId])
  movements     StockMovement[]
  
  dateCreated   DateTime @default(now())
  dateUpdated   DateTime @updatedAt
}

model StockMovement {
  id           Int       @id @default(autoincrement())
  variantId    String
  inventoryId  String
  type         String  // IN | OUT | ADJUST
  quantity     Int
  reference    String?
  description  String? 

  variant      ProductVariant @relation(fields: [variantId], references: [productVariantId])
  inventory    Inventory      @relation(fields: [inventoryId], references: [inventoryId])

  dateCreated  DateTime  @default(now())
  dateUpdated  DateTime  @updatedAt
}

model PaymentMethod {
  id               Int      @id @default(autoincrement())
  paymentMethodId  String   @unique @default(uuid())
  name             String   @unique  // Cash, Card, GCash, etc.
  isActive         Boolean  @default(true)

  sales            Sale[]

  dateCreated      DateTime @default(now())
  dateUpdated      DateTime @updatedAt
}

model Sale {
  id                Int      @id @default(autoincrement())
  saleId            String   @unique @default(uuid())
  saleCode          String   @unique
  totalAmount       Decimal  @db.Decimal(10, 2)
  paymentMethodId   String

  paymentMethod     PaymentMethod @relation(fields: [paymentMethodId], references: [paymentMethodId])
  items             SaleItem[]

  dateCreated       DateTime @default(now())
  dateUpdated       DateTime @updatedAt
}

model SaleItem {
  id           Int      @id @default(autoincrement())
  saleId       String
  variantId    String
  quantity     Int
  unitPrice    Decimal  @db.Decimal(10, 2)
  subtotal     Decimal  @db.Decimal(10, 2)

  sale         Sale           @relation(fields: [saleId], references: [saleId])
  variant      ProductVariant @relation(fields: [variantId], references: [productVariantId])

  dateCreated  DateTime       @default(now())
  dateUpdated  DateTime       @updatedAt
}
